{
  "name": "gscan",
  "version": "5.2.5",
  "description": "Scans Ghost themes looking for errors, deprecations, features and compatibility",
  "keywords": [
    "ghost",
    "themes",
    "validator",
    "lint"
  ],
  "homepage": "https://ghost.org/",
  "repository": {
    "type": "git",
    "url": "git@github.com:TryGhost/gscan.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": "^20.11.1 || ^22.13.1 || ^24.0.0"
  },
  "bugs": {
    "url": "https://github.com/TryGhost/gscan/issues"
  },
  "author": {
    "name": "Ghost Foundation",
    "email": "hello@ghost.org",
    "web": "https://ghost.org/"
  },
  "main": "lib",
  "license": "MIT",
  "scripts": {
    "start": "node app/index.js",
    "dev": "NODE_ENV=development DEBUG=gscan:* nodemon",
    "lint": "eslint . --ext .js --cache",
    "test": "NODE_ENV=testing c8 --check-coverage --branches 95 --functions 95 --lines 95 --statements 95 mocha test/*.test.js",
    "posttest": "yarn lint",
    "preship": "yarn test",
    "ship": "pro-ship",
    "postship": "npm publish"
  },
  "bin": {
    "gscan": "./bin/cli.js"
  },
  "dependencies": {
    "@sentry/node": "10.39.0",
    "@tryghost/config": "1.2.1",
    "@tryghost/debug": "1.2.1",
    "@tryghost/errors": "2.2.1",
    "@tryghost/logging": "3.2.1",
    "@tryghost/nql": "0.12.10",
    "@tryghost/pretty-cli": "2.2.1",
    "@tryghost/server": "1.2.1",
    "@tryghost/zip": "2.2.1",
    "chalk": "5.6.2",
    "common-tags": "^1.8.2",
    "express": "5.2.1",
    "express-hbs": "^2.4.2",
    "fs-extra": "^11.1.1",
    "glob": "^8.1.0",
    "lodash": "^4.17.21",
    "multer": "^2.0.0",
    "pluralize": "^8.0.0",
    "require-dir": "^1.2.0",
    "semver": "^7.5.4",
    "uuid": "13.0.0",
    "validator": "^13.0.0"
  },
  "devDependencies": {
    "@tryghost/pro-ship": "1.0.7",
    "c8": "10.1.3",
    "eslint": "8.1.0",
    "eslint-plugin-ghost": "2.1.0",
    "mocha": "11.7.5",
    "node-fetch": "3.3.2",
    "nodemon": "3.1.14",
    "rewire": "9.0.1",
    "should": "13.2.3",
    "sinon": "21.0.1"
  },
  "files": [
    "lib",
    "bin",
    "app"
  ],
  "renovate": {
    "extends": [
      "@tryghost:quietJS",
      "@tryghost:automergeDevDependencies"
    ],
    "ignoreDeps": [
      "validator"
    ]
  }
}
